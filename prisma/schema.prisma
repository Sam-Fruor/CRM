// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
// Strict roles enforcing your access control matrix
enum Role {
  ADMIN
  MANAGEMENT
  EXAMINER
  SALES
  OPERATIONS
  HR
}

// Strict branches to segment data
enum Branch {
  BRANCH_A
  BRANCH_B
  BRANCH_C
  MASTER // For Admin/Management/Examiner who see everything
}

// --- MODELS ---

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Will store hashed passwords
  role      Role
  branch    Branch
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations: Tracking who handled the lead at what stage
  salesLeads      Lead[] @relation("SalesRepresentative")
  operationsLeads Lead[] @relation("OperationsRepresentative")
  hrLeads         Lead[] @relation("HRRepresentative")
  activities      ActivityLog[]
  notifications   Notification[]
}

model Lead {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branch          Branch   // Dictates which branch owns this lead
  activities      ActivityLog[]
  testEvaluations TestEvaluation[]

  // ----------------------------------------------------
  // FIRST PAGE INFO (Visible to Sales, Ops, HR, Examiner)
  // ----------------------------------------------------
  leadDate         DateTime @default(now())
  leadSource       String   // Facebook, TikTok, WhatsApp, Referral, Others
  leadSourceOther  String?  // If 'Others' is selected
  category         String   // Bus Driver, Trailer Driver, Mechanics, Others
  categoryOther    String?  // If 'Others' is selected
  countryPreferred String   // Latvia, Romania, Croatia, Others
  countryOther     String?  // If 'Others' is selected
  slotBookingDate  DateTime?
  testDate         DateTime?
  
  // Personal Information
  givenName        String
  surname          String
  dob              DateTime?
  fatherName       String?
  passportNum      String?
  passportExpiry   DateTime?
  nationality      String?
  email            String?
  callingNumber    String?
  whatsappNumber   String?
  dlNumber         String?
  dlExpiry         DateTime?
  residentIdNum    String?
  residentIdExp    DateTime?
  homeCountryNumber String?
  experienceHome   Int?
  experienceGCC    Int?
  previousAgency   String?
  previousCountry  String?
  homeAddress      String?
  companyAddress   String?
  passportIssueDate   DateTime?
  dlIssueDate         DateTime?
  residentIdIssueDate DateTime?

  // ----------------------------------------------------
  // STAGE 1: SALES PROCESSING
  // ----------------------------------------------------
  feedbackStatus   String?  // Converted, Not Responding, Not Eligible, etc.
  salesRemarks     String?  @db.Text

  // ----------------------------------------------------
  // STAGE 2: OPERATIONS & HR PROCESSING
  // ----------------------------------------------------
  caseStatus       String   @default("Stage 1 Under Process")
  opsLastActionDate    DateTime?
  opsNextFollowUpDate  DateTime?
  
  // Payment Details
  testFeesAmount         Float?
  totalPayment           Float?
  serviceAgreementPending Float?
  jobOfferPending         Float?
  workPermitPending       Float?
  insurancePending        Float?
  schoolFeesPending       Float?
  flightTicketPending     Float? // From HR view
  otherPending            Float? // Misc
  invoiceNumber           String?
  testFeeRemarks          String?    @db.Text 
  
  reTestFeesAmount        Float?
  reTestDate              DateTime?
  reTestTotalPayment      Float?
  reTestInvoiceNumber     String? 
  reTestPaymentDate       DateTime?
  reTestFeeRemarks        String?    @db.Text 
  
  serviceAgreementAmount      Float?
  serviceAgreementInvoice     String?
  serviceAgreementTotal       Float?
  serviceAgreementPaymentDate DateTime?
  saFeeRemarks                String?    @db.Text 
  
  paymentDate             DateTime?
  
  // 🔐 Payment Verification Gates (Sales)
  testFeeVerifyStatus       String  @default("Unsubmitted")
  testFeeRejectReason       String? 
  testFeeApproveRemark      String? @db.Text // 👈 NEW
  
  reTestFeeVerifyStatus     String  @default("Unsubmitted")
  reTestFeeRejectReason     String? 
  reTestFeeApproveRemark    String? @db.Text // 👈 NEW
  
  saFeeVerifyStatus         String  @default("Unsubmitted")
  saFeeRejectReason         String? 
  saFeeApproveRemark        String? @db.Text // 👈 NEW

  // ----------------------------------------------------
  // ⚙️ OPERATIONS PAYMENT VERIFICATION TRACKING 
  // ----------------------------------------------------
  jobOfferPaymentDate       DateTime?
  jobOfferPaymentRemarks    String?   @db.Text
  jobOfferInvoice           String?
  jobOfferVerifyStatus      String    @default("Unsubmitted")
  jobOfferRejectReason      String?
  jobOfferApproveRemark     String?   @db.Text // 👈 NEW

  workPermitPaymentDate     DateTime?
  workPermitPaymentRemarks  String?   @db.Text
  workPermitInvoice         String?
  workPermitVerifyStatus    String    @default("Unsubmitted")
  workPermitRejectReason    String?
  workPermitApproveRemark   String?   @db.Text // 👈 NEW

  insurancePaymentDate      DateTime?
  insurancePaymentRemarks   String?   @db.Text
  insuranceInvoice          String?
  insuranceVerifyStatus     String    @default("Unsubmitted")
  insuranceRejectReason     String?
  insuranceApproveRemark    String?   @db.Text // 👈 NEW

  schoolFeesPaymentDate     DateTime?
  schoolFeesPaymentRemarks  String?   @db.Text
  schoolFeesInvoice         String?
  schoolFeesVerifyStatus    String    @default("Unsubmitted")
  schoolFeesRejectReason    String?
  schoolFeesApproveRemark   String?   @db.Text // 👈 NEW

  flightTicketPaymentDate     DateTime?
  flightTicketPaymentRemarks  String?   @db.Text
  flightTicketInvoice         String?
  flightTicketVerifyStatus    String    @default("Unsubmitted")
  flightTicketRejectReason    String?
  flightTicketApproveRemark   String?   @db.Text // 👈 NEW

  otherPendingPaymentDate     DateTime?
  otherPendingPaymentRemarks  String?   @db.Text
  otherPendingInvoice         String?
  otherPendingVerifyStatus    String    @default("Unsubmitted")
  otherPendingRejectReason    String?
  otherPendingApproveRemark   String?   @db.Text // 👈 NEW

  // ♾️ DYNAMIC PAYMENTS LEDGER
  otherPayments             Json      @default("[]") 

  // ----------------------------------------------------
  // FOLLOW-UP DETAILS (TAB-SPECIFIC)
  // ----------------------------------------------------
  // Profile Tab (Default)
  lastCallDate      DateTime?
  followUpDate      DateTime?
  followUpRemarks   String?    @db.Text

  // Documents Tab
  documentsLastCallDate      DateTime?
  documentsFollowUpDate      DateTime?
  documentsFollowUpRemarks   String?    @db.Text
  documentsSalesRemarks      String?    @db.Text

  // Testing Tab
  testingLastCallDate        DateTime?
  testingFollowUpDate        DateTime?
  testingFollowUpRemarks     String?    @db.Text
  testingSalesRemarks        String?    @db.Text

  // Service Agreement Tab
  saLastCallDate             DateTime?
  saFollowUpDate             DateTime?
  saFollowUpRemarks          String?    @db.Text
  saSalesRemarks             String?    @db.Text

  // HR & Ops Remarks
  lastEmailDate      DateTime?
  hrNextFollowUpDate DateTime?
  hrRemarks          String?    @db.Text
  opsRemarks         String?    @db.Text

  // ----------------------------------------------------
  // DOCUMENTS (Operations & HR)
  // ----------------------------------------------------
  documentStatus    Json     @default("{}") 
  documentFiles     Json     @default("{}") 
  documentChecklist Json     @default("{}")

  // ----------------------------------------------------
  // STAGE 3: EXAMINER
  // ----------------------------------------------------
  englishScore      Int?
  drivingScore      Int?
  englishTestResult String?  // Passed / Failed / Practice Required
  yardTestResult    String?  // Passed / Failed / Practice Required
  examinerStatus    String?  // "Approved", "Denied", "Pending"
  examinerRemarks   String?  @db.Text

  // ----------------------------------------------------
  // ASSIGNMENTS
  // ----------------------------------------------------
  salesRepId        String?
  salesRep          User?    @relation("SalesRepresentative", fields: [salesRepId], references: [id])
  
  opsRepId          String?
  opsRep            User?    @relation("OperationsRepresentative", fields: [opsRepId], references: [id])
  
  hrRepId           String?
  hrRep             User?    @relation("HRRepresentative", fields: [hrRepId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  action    String   
  details   String?  
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   
  title     String
  message   String
  link      String?  
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestEvaluation {
  id                String   @id @default(cuid())
  leadId            String
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  englishScore      Int?
  englishTestResult String?
  drivingScore      Int?
  yardTestResult    String?
  status            String   
  remarks           String?  @db.Text
  
  createdAt         DateTime @default(now())
}